<!DOCTYPE html>

<html class="light" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Synapse AI | Your Knowledge Base, Conversational</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&amp;family=Inter:wght@400;600&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              error: "#ba1a1a",
              "on-tertiary-fixed": "#191b29",
              "surface-container-highest": "#e2e2e4",
              "surface-bright": "#f9f9fb",
              "on-secondary": "#ffffff",
              "on-surface-variant": "#3f484c",
              "on-tertiary-container": "#4e5060",
              "inverse-surface": "#2f3132",
              "surface-container": "#edeef0",
              tertiary: "#5c5d6e",
              "error-container": "#ffdad6",
              "on-primary-fixed": "#001f29",
              "primary-container": "#87ceeb",
              "surface-container-high": "#e8e8ea",
              "on-tertiary": "#ffffff",
              surface: "#f9f9fb",
              "tertiary-container": "#c2c3d6",
              "inverse-on-surface": "#f0f0f2",
              "secondary-container": "#fdcde1",
              "tertiary-fixed": "#e1e1f5",
              outline: "#6f787d",
              "on-primary-container": "#005870",
              "inverse-primary": "#89d0ed",
              primary: "#0c6780",
              "surface-variant": "#e2e2e4",
              "tertiary-fixed-dim": "#c5c5d8",
              "surface-tint": "#0c6780",
              "surface-container-low": "#f3f3f5",
              "secondary-fixed": "#ffd8e7",
              "on-secondary-fixed-variant": "#5f3c4d",
              secondary: "#795465",
              "secondary-fixed-dim": "#e9bacd",
              "primary-fixed": "#baeaff",
              "on-error": "#ffffff",
              "on-background": "#1a1c1d",
              "on-primary": "#ffffff",
              "on-surface": "#1a1c1d",
              "on-secondary-container": "#795465",
              background: "#f9f9fb",
              "surface-container-lowest": "#ffffff",
              "on-tertiary-fixed-variant": "#444655",
              "on-error-container": "#93000a",
              "primary-fixed-dim": "#89d0ed",
              "surface-dim": "#d9dadc",
              "on-primary-fixed-variant": "#004d62",
              "outline-variant": "#bfc8cd",
              "on-secondary-fixed": "#2e1221",
            },
            borderRadius: {
              DEFAULT: "0.5rem",
              lg: "1rem",
              xl: "1.5rem",
              full: "9999px",
            },
            animation: {
              "cursor-blink": "blink 1s step-end infinite",
              "stream-reveal": "reveal 0.5s ease-out forwards",
              "float-slow": "float 6s ease-in-out infinite",
            },
            keyframes: {
              blink: { "from, to": { opacity: "1" }, "50%": { opacity: "0" } },
              reveal: {
                from: { opacity: "0", transform: "translateY(4px)" },
                to: { opacity: "1", transform: "translateY(0)" },
              },
              float: {
                "0%, 100%": { transform: "translateY(0)" },
                "50%": { transform: "translateY(-10px)" },
              },
            },
          },
        },
      };
    </script>
    <style>
      body {
        font-family: "Inter", sans-serif;
        background-color: #f9f9fb;
        color: #1a1c1d;
      }
    </style>
  </head>
  <body
    class="relative min-h-screen overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container"
  >
    <div class="atmospheric-bg">
      <!-- Abstract SVG Background Nodes -->
      <svg
        class="absolute top-20 left-10 opacity-20"
        height="200"
        viewbox="0 0 200 200"
        width="200"
        xmlns="http://www.w3.org/2000/svg"
      >
        <circle cx="20" cy="20" fill="#4e77bd" r="2"></circle>
        <circle cx="180" cy="180" fill="#4e77bd" r="3"></circle>
        <path
          d="M20 20 Q 100 100 180 180"
          fill="transparent"
          stroke="#4e77bd"
          stroke-width="0.5"
        ></path>
      </svg>
      <svg
        class="absolute bottom-40 right-20 opacity-10"
        height="300"
        viewbox="0 0 300 300"
        width="300"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M50 250 C 150 50 250 150 300 50"
          fill="transparent"
          stroke="#4e77bd"
          stroke-dasharray="4 4"
          stroke-width="1"
        ></path>
      </svg>
    </div>
    <!-- Navigation (Floating Glass Bar) -->
  
    <!-- Hero Section -->
    <section
      class="pt-40 pb-24 px-6 flex flex-col items-center text-center relative"
    >
      <div class="max-w-4xl mx-auto space-y-6">
        <h1
          class="text-5xl md:text-7xl font-extrabold tracking-tight text-on-surface leading-[1.1]"
        >
          Your knowledge base, <br class="hidden md:block" />
          <span
            class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
            >instantly conversational.</span
          >
        </h1>
        <p
          class="text-lg md:text-xl text-on-surface-variant max-w-2xl mx-auto leading-relaxed"
        >
          Upload PDFs, docs, or notes and get accurate, context-aware answers in
          seconds using AI-powered semantic search.
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4"
        >
          <button
            class="bg-primary text-on-primary px-8 py-4 rounded-xl text-base font-bold shadow-xl shadow-primary/20 btn-interact primary-gradient-hover"
          >
            Start Chatting
          </button>
          <button
            class="glass-pane px-8 py-4 rounded-xl text-base font-bold border-white/60 hover:bg-white/60 transition-colors btn-interact"
          >
            View Demo
          </button>
        </div>
        <p class="text-xs font-semibold text-outline tracking-wide pt-2">
          No setup required • Works in seconds
        </p>
      </div>
      <!-- Central Chat Interface -->
      <div class="mt-20 relative w-full max-w-4xl mx-auto">
        <!-- Glow Backdrop -->
        <div
          class="absolute -inset-4 bg-primary-container/10 blur-3xl rounded-3xl opacity-50"
        ></div>
        <!-- Main Chat Glass Card -->
        <div
          class="glass-pane rounded-xl p-6 md:p-8 shadow-2xl relative z-10 overflow-hidden border-white/40"
        >
          <div class="space-y-6">
            <!-- AI Message -->
            <div class="flex items-start gap-4 text-left msg-1">
              <div
                class="size-10 rounded-full bg-primary flex items-center justify-center shrink-0"
              >
                <span
                  class="material-symbols-outlined text-white"
                  style="font-variation-settings: &quot;FILL&quot; 1"
                  >smart_toy</span
                >
              </div>
              <div class="space-y-2">
                <div
                  class="bg-surface-container-low rounded-lg p-4 text-sm text-on-surface-variant border border-outline-variant/30 leading-relaxed max-w-[90%]"
                >
                  Hello! I've indexed your workspace. How can I help you
                  navigate your documentation today?
                </div>
              </div>
            </div>
            <!-- Streaming Response Simulation -->
            <div class="flex items-start gap-4 text-left msg-2">
              <div
                class="size-10 rounded-full bg-primary flex items-center justify-center shrink-0"
              >
                <span
                  class="material-symbols-outlined text-white"
                  style="font-variation-settings: &quot;FILL&quot; 1"
                  >smart_toy</span
                >
              </div>
              <div class="space-y-2 w-full">
                <div
                  class="bg-surface-container-low rounded-lg p-4 text-sm text-on-surface border border-outline-variant/30 leading-relaxed max-w-[85%]"
                >
                  <span class="animate-stream-reveal"
                    >Based on the uploaded project roadmap, the core milestones
                    are...</span
                  >
                  <div
                    class="mt-2 typing-indicator text-primary flex gap-1 items-center"
                  >
                    <span class="size-1 rounded-full bg-current"></span>
                    <span class="size-1 rounded-full bg-current"></span>
                    <span class="size-1 rounded-full bg-current"></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Input Box -->
          <div class="mt-12">
            <div
              class="glass-pane bg-white/60 rounded-xl p-2 flex items-center gap-3 border border-primary/20 shadow-inner"
            >
              <button
                class="p-2 hover:bg-surface-container rounded-lg transition-colors text-outline btn-interact"
              >
                <span class="material-symbols-outlined" data-icon="add"
                  >add</span
                >
              </button>
              <div
                class="flex-1 py-3 px-1 text-sm md:text-base text-on-surface/60 flex items-center"
              >
                <span class="text-on-surface/40">Search documents...</span>
                <span class="input-cursor ml-1"></span>
              </div>
              <button
                class="bg-primary text-on-primary p-3 rounded-lg hover:bg-primary/90 transition-all shadow-md btn-interact"
              >
                <span class="material-symbols-outlined text-sm" data-icon="send"
                  >send</span
                >
              </button>
            </div>
          </div>
        </div>
        <!-- Floating Status Cards -->
        <div
          class="hidden lg:block absolute -left-20 top-1/4 glass-pane p-4 rounded-xl shadow-lg border-white/60 animate-float-slow"
        >
          <div class="flex items-center gap-3">
            <div
              class="size-8 rounded-full bg-green-100 flex items-center justify-center text-green-600"
            >
              <span
                class="material-symbols-outlined text-sm"
                style="font-variation-settings: &quot;FILL&quot; 1"
                >check_circle</span
              >
            </div>
            <div class="text-left">
              <p class="text-xs font-bold text-on-surface">98% Accuracy</p>
              <p class="text-[10px] text-on-surface-variant">Retrieval Score</p>
            </div>
          </div>
        </div>
        <div
          class="hidden lg:block absolute -right-16 top-10 glass-pane p-4 rounded-xl shadow-lg border-white/60"
        >
          <div class="flex flex-col gap-2">
            <p
              class="text-[10px] font-bold text-outline uppercase tracking-widest"
            >
              Connected Sources
            </p>
            <div class="flex -space-x-2">
              <div
                class="size-8 rounded-full bg-white border-2 border-surface-container flex items-center justify-center shadow-sm"
              >
                <img
                  class="size-4"
                  data-alt="minimal slack logo icon color teal"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuD-9gkLfJ1eorOtybhvmYSJBX_S3wiXZG2MKOmgUvpGA2jI3C6iQHCqLlZy991rs02fS0SioYA4V3wQbvWMi2vf_az3XpwcT_V3VpOfhhrcyMvitBdiwHy6S0fcKrlMyhlMmCVDSZE081JXld5INjnWnE6OBoQMhQH1qBeA8CqIn7uQycZ52rNvv5lxsb3EMKBOGD03OK5GBRGwPyY691M6HXWhqlD1Xog4piEsEPHWCmpGSHrCtsULN0qtl8X1ISeuCq7AeqRJOyI"
                />
              </div>
              <div
                class="size-8 rounded-full bg-white border-2 border-surface-container flex items-center justify-center shadow-sm"
              >
                <img
                  class="size-4"
                  data-alt="minimal notion logo icon black"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuBaS6hjjZd4i54nB3EJBDjcG-froPxjQqpGAedlAnUEo1eN0W4SabaaqoFVFY8XpnhCOZJSwfoFE2BQEz33t8PmEDBQcbDWkSLUTWEj3HhobGi68XsFKd2LI50UUZhGTF1XXAKsfbTKU-Bg3HV34xuSfMEr9WDdtnHp2EcAQD0awaH_bLfywEmHZQJHjhvbn2uStlsxxEx8o0GVT_2vlOhEt5z26rLt52KplDzt_TnRVUYy06ZF_2t47iPzaEP3iJEESc0MZ1lLAK4"
                />
              </div>
              <div
                class="size-8 rounded-full bg-white border-2 border-surface-container flex items-center justify-center shadow-sm text-[10px] font-bold text-on-surface-variant"
              >
                +52
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- How it Works Section -->
    <section class="py-24 max-w-6xl mx-auto px-6 relative">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-on-surface">
          Effortless Intelligence
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-12 relative">
        <!-- Animated Connection Lines (Desktop) -->
        <div
          class="hidden md:block absolute top-12 left-1/3 w-1/3 h-px bg-gradient-to-r from-primary/30 via-primary to-primary/30 opacity-50"
        ></div>
        <div
          class="hidden md:block absolute top-12 left-2/3 w-1/3 h-px bg-gradient-to-r from-primary/30 via-primary to-primary/30 opacity-50"
        ></div>
        <div class="text-center space-y-4">
          <div
            class="size-14 mx-auto rounded-full bg-primary/10 flex items-center justify-center text-primary relative z-10 border border-primary/20"
          >
            <span class="material-symbols-outlined">upload_file</span>
          </div>
          <h3 class="font-bold text-lg">1. Upload Documents</h3>
          <p class="text-on-surface-variant text-sm">
            Add PDFs or text files to your secure workspace
          </p>
        </div>
        <div class="text-center space-y-4">
          <div
            class="size-14 mx-auto rounded-full bg-primary/10 flex items-center justify-center text-primary relative z-10 border border-primary/20"
          >
            <span class="material-symbols-outlined">memory</span>
          </div>
          <h3 class="font-bold text-lg">2. AI Processing</h3>
          <p class="text-on-surface-variant text-sm">
            We convert your data into searchable semantic embeddings
          </p>
        </div>
        <div class="text-center space-y-4">
          <div
            class="size-14 mx-auto rounded-full bg-primary/10 flex items-center justify-center text-primary relative z-10 border border-primary/20"
          >
            <span class="material-symbols-outlined">forum</span>
          </div>
          <h3 class="font-bold text-lg">3. Ask Questions</h3>
          <p class="text-on-surface-variant text-sm">
            Get precise, contextual answers instantly
          </p>
        </div>
      </div>
    </section>
    <!-- Features Section -->
    <section class="py-24 max-w-6xl mx-auto px-6">
      <div class="text-center mb-16 space-y-4">
        <h2 class="text-3xl md:text-5xl font-bold text-on-surface">
          Powerful, precise, private.
        </h2>
        <p class="text-on-surface-variant max-w-xl mx-auto">
          Smarter workflows, built on your data, secured by design.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <!-- Feature 1 -->
        <div
          class="md:col-span-8 glass-pane rounded-xl p-8 card-hover flex flex-col justify-between min-h-[280px]"
        >
          <div>
            <div
              class="size-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-6"
            >
              <span class="material-symbols-outlined">search_insights</span>
            </div>
            <h3 class="text-xl font-bold mb-2">Semantic Search</h3>
            <p class="text-on-surface-variant text-sm max-w-md leading-relaxed">
              Go beyond keyword matching. Our AI understands the context and
              intent of your queries to find the exact information you need.
            </p>
          </div>
          <div class="flex gap-2 pt-6">
            <span
              class="bg-surface-container px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight"
              >Contextual Intent</span
            >
            <span
              class="bg-surface-container px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight"
              >Neural Ranking</span
            >
          </div>
        </div>
        <!-- Feature 2 -->
        <div
          class="md:col-span-4 glass-pane rounded-xl p-8 card-hover min-h-[280px]"
        >
          <div
            class="size-12 rounded-lg bg-secondary/10 flex items-center justify-center text-secondary mb-6"
          >
            <span class="material-symbols-outlined">auto_awesome</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Context-Aware AI</h3>
          <p class="text-on-surface-variant text-sm">
            Answers that respect the hierarchy and relationships within your
            specific documentation set.
          </p>
        </div>
        <!-- Feature 3 -->
        <div
          class="md:col-span-4 glass-pane rounded-xl p-8 card-hover min-h-[280px]"
        >
          <div
            class="size-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-6"
          >
            <span class="material-symbols-outlined">stream</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Real-time Streaming</h3>
          <p class="text-on-surface-variant text-sm">
            Experience ultra-fast responses that generate word-by-word as the AI
            thinks, reducing perceived latency.
          </p>
        </div>
        <!-- Feature 4 -->
        <div
          class="md:col-span-8 glass-pane rounded-xl p-8 card-hover min-h-[280px]"
        >
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-xl font-bold mb-2">Source Citations</h3>
              <p class="text-on-surface-variant text-sm max-w-sm">
                Every answer comes with verified links back to the source
                document. No hallucinations, just reliable facts you can
                double-check.
              </p>
            </div>
            <div
              class="size-16 rounded-full border border-primary/20 flex items-center justify-center bg-primary/5"
            >
              <span class="material-symbols-outlined text-primary text-3xl"
                >fact_check</span
              >
            </div>
          </div>
          <div
            class="mt-8 bg-white/40 border border-white/60 rounded-lg p-3 text-xs font-mono text-outline italic"
          >
            "According to [Q4_Ops_Manual.pdf], Section 2.1..."
          </div>
        </div>
        <!-- Feature 5 -->
        <div
          class="md:col-span-6 glass-pane rounded-xl p-8 card-hover min-h-[200px]"
        >
          <h3 class="text-xl font-bold mb-2">Multi-document Support</h3>
          <p class="text-on-surface-variant text-sm">
            Synthesize information across dozens of files simultaneously to get
            a complete picture of any topic.
          </p>
        </div>
        <!-- Feature 6 -->
        <div
          class="md:col-span-6 glass-pane rounded-xl p-8 card-hover min-h-[200px]"
        >
          <h3 class="text-xl font-bold mb-2">Secure Processing</h3>
          <p class="text-on-surface-variant text-sm">
            Enterprise-grade encryption and isolated data tenants ensure your
            proprietary information remains confidential.
          </p>
        </div>
      </div>
    </section>
    <!-- Use Cases Section -->
    <section class="py-24 bg-surface-container/20">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-center mb-16">
          Built for everyone who reads.
        </h2>
        <div class="grid md:grid-cols-4 gap-6">
          <div class="glass-pane p-6 rounded-xl card-hover">
            <div class="text-primary mb-4">
              <span class="material-symbols-outlined">school</span>
            </div>
            <h4 class="font-bold mb-2">Students</h4>
            <p class="text-xs text-on-surface-variant">
              Summarize textbooks and clarify complex theories from lecture
              notes in seconds.
            </p>
          </div>
          <div class="glass-pane p-6 rounded-xl card-hover">
            <div class="text-primary mb-4">
              <span class="material-symbols-outlined">code</span>
            </div>
            <h4 class="font-bold mb-2">Developers</h4>
            <p class="text-xs text-on-surface-variant">
              Instant answers from dense API documentation and legacy codebase
              wikis.
            </p>
          </div>
          <div class="glass-pane p-6 rounded-xl card-hover">
            <div class="text-primary mb-4">
              <span class="material-symbols-outlined">groups</span>
            </div>
            <h4 class="font-bold mb-2">Teams</h4>
            <p class="text-xs text-on-surface-variant">
              Onboard new members faster by letting them chat with your team's
              internal knowledge base.
            </p>
          </div>
          <div class="glass-pane p-6 rounded-xl card-hover">
            <div class="text-primary mb-4">
              <span class="material-symbols-outlined">science</span>
            </div>
            <h4 class="font-bold mb-2">Researchers</h4>
            <p class="text-xs text-on-surface-variant">
              Analyze mountains of research papers and extract key data points
              without the manual slog.
            </p>
          </div>
        </div>
      </div>
    </section>
    <!-- Final CTA -->
    <section class="py-32 px-6">
      <div
        class="max-w-5xl mx-auto glass-pane rounded-[2rem] p-12 md:p-24 text-center relative overflow-hidden border-white/50 shadow-2xl"
      >
        <!-- Subtle Animated Gradient Background -->
        <div
          class="absolute inset-0 bg-gradient-to-br from-primary/10 via-surface-container-low to-secondary/10 opacity-30 animate-pulse"
          style="animation-duration: 10s"
        ></div>
        <div class="relative z-10 space-y-8">
          <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight">
            Start chatting with your <br class="hidden md:block" />
            documents today
          </h2>
          <p class="text-on-surface-variant text-lg max-w-xl mx-auto">
            Save hours of manual reading with AI-powered answers that are always
            cited and secure.
          </p>
          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <button
              class="bg-primary text-on-primary px-10 py-5 rounded-xl text-lg font-bold shadow-xl shadow-primary/20 btn-interact primary-gradient-hover w-full sm:w-auto"
            >
              Try it Free
            </button>
            <button
              class="glass-pane px-10 py-5 rounded-xl text-lg font-bold border-white/60 hover:bg-white/60 transition-colors btn-interact w-full sm:w-auto"
            >
              Talk to Sales
            </button>
          </div>
          <div
            class="pt-8 flex items-center justify-center gap-8 opacity-60 grayscale scale-90"
          >
            <span class="text-xs font-bold uppercase tracking-widest"
              >SOC 2 TYPE II</span
            >
            <span class="text-xs font-bold uppercase tracking-widest"
              >HIPAA COMPLIANT</span
            >
            <span class="text-xs font-bold uppercase tracking-widest"
              >GDPR READY</span
            >
          </div>
        </div>
      </div>
    </section>
    <!-- Footer -->
  </body>
</html>
